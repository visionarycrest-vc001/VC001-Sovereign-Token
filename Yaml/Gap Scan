name: Gap Scan

on:
  push:
    branches: [main]
  pull_request:

jobs:
  gap-scan:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install PackCC and jq
        run: |
          sudo apt-get update
          sudo apt-get install -y jq wget gcc
          wget -O packcc https://github.com/arithy/packcc/releases/download/v1.7.3/packcc-linux
          chmod +x packcc
          sudo mv packcc /usr/local/bin/

      - name: Build parser
        working-directory: parsers
        run: make all PACKCC=packcc

